# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=graffmap
POSTGRES_USER=graffmap
POSTGRES_PASSWORD=change_me_strong_password

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# Comma-separated list of admin email addresses that may request a magic link
ADMIN_EMAILS=admin@yourdomain.com

MAGIC_LINK_EXPIRE_MINUTES=15
SESSION_EXPIRE_HOURS=24

# ── Upload ─────────────────────────────────────────────────────────────────
UPLOAD_PASSWORD=change_me_upload_password

# ── App ────────────────────────────────────────────────────────────────────
# Used to build the magic-link URL in emails
APP_URL=https://yourdomain.com

# ── SMTP — choose one mode: host | relay | external ───────────────────────
SMTP_MODE=host
SMTP_FROM=noreply@yourdomain.com

# Option A — VPS postfix/exim4 via Docker host-gateway (SMTP_MODE=host)
# No extra container needed.  The host's mail daemon must accept relay from
# the Docker subnet (127.0.0.0/8 or the bridge network CIDR).
SMTP_HOST_GATEWAY=host-gateway
SMTP_HOST_PORT=25

# Option B — boky/postfix relay container (SMTP_MODE=relay)
# Start with: docker compose --profile smtp-relay up -d
SMTP_RELAY_HOST=smtp-relay
SMTP_RELAY_PORT=25
SMTP_RELAY_DOMAIN=yourdomain.com   # domains postfix is allowed to send from

# Option C — external SMTP server (SMTP_MODE=external)
SMTP_EXTERNAL_HOST=mail.yourdomain.com
SMTP_EXTERNAL_PORT=587
SMTP_EXTERNAL_USER=noreply@yourdomain.com
SMTP_EXTERNAL_PASSWORD=your_smtp_password
SMTP_EXTERNAL_TLS=true    # STARTTLS on port 587
SMTP_EXTERNAL_SSL=false   # set true and port 465 for implicit TLS
